{
  "Contact": {
    "Uploads": {
      "MaxFilesPerMessage": 10,
      "MaxBytesPerFile": 10485760,
      "AllowedExtensions": [
        ".pdf",
        ".png",
        ".jpg",
        ".jpeg",
        ".webp",
        ".gif",
        ".doc",
        ".docx",
        ".xls",
        ".xlsx",
        ".txt",
        ".zip"
      ]
    }
  },
  "Database": {
    "ApplyMigrationsOnStartup": true,
    "PreferIpv4Dns": true
  },
  "Cors": {
    "AllowedOrigins": [
      "https://nexgensoft.vercel.app",
      "https://nexgensoft.tr",
      "https://www.nexgensoft.tr"
    ]
  },
  "Seed": {
    "EnableSiteContentSeed": true
  },
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
