{
  "Audit": {
    "Enabled": true,
    "LogRequestBody": false,
    "MaxRequestBodyCharsToStore": 2000,
    "ExcludedPathPrefixes": []
  },
  "Contact": {
    "Uploads": {
      "MaxFilesPerMessage": 10,
      "MaxBytesPerFile": 10485760,
      "AllowedExtensions": [
        ".pdf",
        ".png",
        ".jpg",
        ".jpeg",
        ".webp",
        ".gif",
        ".doc",
        ".docx",
        ".xls",
        ".xlsx",
        ".txt",
        ".zip"
      ]
    }
  },
  "Application": {
    "Uploads": {
      "MaxFilesPerApplication": 10,
      "MaxBytesPerFile": 10485760,
      "AllowedExtensions": [
        ".pdf",
        ".png",
        ".jpg",
        ".jpeg",
        ".webp",
        ".gif",
        ".doc",
        ".docx",
        ".xls",
        ".xlsx",
        ".txt",
        ".zip"
      ]
    }
  },
  "Database": {
    "ApplyMigrationsOnStartup": true,
    "PreferIpv4Dns": true
  },
  "Cors": {
    "AllowedOrigins": [
      "https://nexgensoft.vercel.app",
      "https://nexgensoft.tr",
      "https://www.nexgensoft.tr"
    ]
  },
  "Jwt": {
    "Issuer": "Nexgensoft",
    "Audience": "Nexgensoft"
  },
  "Seed": {
    "EnableSiteContentSeed": true,
    "EnableAdminUserSeed": false,
    "AdminUser": {
      "Email": "admin@nexgensoft.local",
      "Password": ""
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
